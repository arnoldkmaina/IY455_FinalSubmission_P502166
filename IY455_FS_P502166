CREATE DATABASE LoanManagement;
USE LoanManagement;

CREATE TABLE BorrowerInfo3NF (
borrower_no VARCHAR(10) PRIMARY KEY,
borrower_name VARCHAR(100) NOT NULL,
borrower_address VARCHAR(255),
borrower_status VARCHAR(20) CHECK (borrower_status IN ('Active', 'Dormant', 'Suspended', 'Terminated'))
);

CREATE TABLE LoanInfo3NF (
loan_no VARCHAR(10) PRIMARY KEY,
borrower_no VARCHAR(10) NOT NULL,
loan_date DATE NOT NULL,
FOREIGN KEY (borrower_no) REFERENCES BorrowerInfo3NF(borrower_no)
);

CREATE TABLE RentalCategory3NF (
rental_category_id VARCHAR(10) PRIMARY KEY,
rental_category_name VARCHAR(30) NOT NULL,
rental_duration VARCHAR(20) NOT NULL,
rental_cost DECIMAL(10,2) NOT NULL,
fine_charge DECIMAL(10,2) NOT NULL
);

CREATE TABLE DVDInfo3NF (
dvd_no VARCHAR(10) PRIMARY KEY,
dvd_title VARCHAR(100) NOT NULL,
dvd_starring_actor VARCHAR(100),
dvd_year INT,
rental_category_id VARCHAR(10) NOT NULL,
FOREIGN KEY (rental_category_id) REFERENCES RentalCategory3NF(rental_category_id)
);

CREATE TABLE DVDCopy3NF (
copy_no VARCHAR(10) PRIMARY KEY,
dvd_no VARCHAR(10) NOT NULL,
shelf_position VARCHAR(20),
dvd_status VARCHAR(20) CHECK (dvd_status IN ('Available', 'On Loan', 'Overdue', 'Reserved', 'Missing')),
FOREIGN KEY (dvd_no) REFERENCES DVDInfo3NF(dvd_no)
);

CREATE TABLE LoanItem3NF (
loan_no VARCHAR(10) NOT NULL,
copy_no VARCHAR(10) NOT NULL,
return_due_date DATE NOT NULL,
actual_return_date DATE,
loan_fine_charge DECIMAL(10,2) DEFAULT 0.00,
PRIMARY KEY (loan_no, copy_no),
FOREIGN KEY (loan_no) REFERENCES LoanInfo3NF(loan_no),
FOREIGN KEY (copy_no) REFERENCES DVDCopy3NF(copy_no)
);

